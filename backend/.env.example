# Reflex Training - Environment Variables

# AI Provider Selection (gemini | openai | huggingface | ollama)
AI_PROVIDER=gemini

# Provider API Keys (Fill in the ones you use)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Session Configuration
SESSION_TIME_LIMIT_SECONDS=180

# Database
SQLITE_PATH=data/reflex.db

# Performance & Concurrency Limits
LLM_REPLY_TIMEOUT_SECONDS=15.0
LLM_RATE_TIMEOUT_SECONDS=60.0
WS_QUEUE_MAX_SIZE=50
